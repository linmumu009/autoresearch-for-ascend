# Baseline candidate for the MindSpeed-LLM autoresearch runner.
#
# Source through:
#   CANDIDATE_ENV=/workspace/framework_adapters/mindspeed_llm/candidates/baseline_6step.env \
#     bash /workspace/framework_adapters/mindspeed_llm/run_autoresearch_candidate.sh

RUN_NAME=mindspeed_qwen3_0p6_baseline_6step
TRAIN_ITERS=6
DATA_SPLIT=90,10,0
EVAL_INTERVAL=3
EVAL_ITERS=2
SEQ_LENGTH=2048
GLOBAL_BATCH_SIZE=1
MICRO_BATCH_SIZE=1
LR=1.25e-6
EVAL_SEQ_LEN=512
EVAL_BATCH_SIZE=1
